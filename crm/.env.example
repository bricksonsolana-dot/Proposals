# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — never commit secrets.

# Postgres connection string (Session Pooler from Supabase, port 5432)
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Sync token for lead-finder → CRM API
SYNC_TOKEN=change-me-to-a-long-random-string

# Optional: override Flask port
PORT=5001

# Optional: explicit secret key (otherwise auto-generated and persisted)
# SECRET_KEY=
