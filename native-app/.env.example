# Local Android signing — copy this to .env (gitignored) and fill the
# real values. CI uses GitHub repo secrets instead, set in
# Settings → Secrets and variables → Actions.

# Absolute path to the .keystore file
DEVOX_KEYSTORE_PATH=

# Password for the keystore itself
DEVOX_KEYSTORE_PASSWORD=

# Alias of the key inside the keystore
DEVOX_KEY_ALIAS=devox

# Password for that specific key (often same as keystore password)
DEVOX_KEY_PASSWORD=
